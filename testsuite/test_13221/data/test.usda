#usda 1.0
(
    defaultPrim = "grid"
    doc = """Exercises Hydra CoordSys support with *multiple coordinate systems
             sharing a name*. Four grids each reference the same </grid>
             template, so each has its own projector camera and its own copy of
             the material overriding the projection space. All four coordinate
             systems are named 'map_proj' but are bound to different cameras.

             Arnold resolves named coordinate spaces globally by camera node
             name, so a naive translation collides all four on a single camera
             and three grids project from the wrong projector. arnold-usd names
             each coord-sys camera uniquely and rewrites every material's
             'space' input to the camera bound to its rprim, so each grid
             projects from its own camera. The four grids additionally exercise
             the .camera / .NDC / .raster / .screen projective spaces.

             See #32 / ARNOLD-13221."""
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "grid" (
    active = false
    prepend apiSchemas = ["CoordSysAPI:map_proj"]
    kind = "component"
)
{
    rel coordSys:map_proj:binding = </grid/proj_cam>

    def Mesh "mesh" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        float3[] extent = [(-5, 0, -5), (5, 0, 5)]
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        rel material:binding = </grid/mtl/projected>
        point3f[] points = [(-5, 0, 5), (5, 0, 5), (5, 0, -5), (-5, 0, -5)]
        uniform token subdivisionScheme = "none"
    }

    def Camera "proj_cam"
    {
        float2 clippingRange = (0.1, 10000)
        float focalLength = 24
        float horizontalAperture = 36
        token projection = "perspective"
        float verticalAperture = 27
        float xformOp:rotateX = -56
        double3 xformOp:translate = (0, 12, 8)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }

    def Scope "mtl"
    {
        def Material "projected"
        {
            token outputs:mtlx:surface.connect = </grid/mtl/projected/surface.outputs:out>

            def Shader "surface"
            {
                uniform token info:id = "ND_surface_unlit"
                float inputs:emission = 1
                color3f inputs:emission_color.connect = </grid/mtl/projected/rgb.outputs:out>
                token outputs:out
            }

            def Shader "rgb"
            {
                uniform token info:id = "ND_combine3_color3"
                float inputs:in1.connect = </grid/mtl/projected/range_u.outputs:out>
                float inputs:in2.connect = </grid/mtl/projected/range_v.outputs:out>
                float inputs:in3 = 0
                color3f outputs:out
            }

            def Shader "range_u"
            {
                uniform token info:id = "ND_range_float"
                float inputs:in.connect = </grid/mtl/projected/separate.outputs:outx>
                float inputs:inhigh = 5
                float inputs:inlow = -5
                float inputs:outhigh = 1
                float inputs:outlow = 0
                float outputs:out
            }

            def Shader "range_v"
            {
                uniform token info:id = "ND_range_float"
                float inputs:in.connect = </grid/mtl/projected/separate.outputs:outy>
                float inputs:inhigh = 5
                float inputs:inlow = -5
                float inputs:outhigh = 1
                float inputs:outlow = 0
                float outputs:out
            }

            def Shader "separate"
            {
                uniform token info:id = "ND_separate3_vector3"
                vector3f inputs:in.connect = </grid/mtl/projected/position.outputs:out>
                float outputs:outx
                float outputs:outy
                float outputs:outz
            }

            def Shader "position"
            {
                uniform token info:id = "ND_position_vector3"
                string inputs:space = "map_proj"
                vector3f outputs:out
            }
        }
    }
}

def "grid_0" (
    active = true
    append references = </grid>
)
{
    double3 xformOp:translate = (0, 0, 0)
    uniform token[] xformOpOrder = ["xformOp:translate"]

    over "mtl"
    {
        over "projected"
        {
            over "position"
            {
                string inputs:space = "map_proj"
            }
        }
    }
}

def "grid_1" (
    active = true
    append references = </grid>
)
{
    double3 xformOp:translate = (12, 0, 0)
    uniform token[] xformOpOrder = ["xformOp:translate"]

    over "mtl"
    {
        over "projected"
        {
            over "position"
            {
                string inputs:space = "map_proj:ndc"
            }
        }
    }
}

def "grid_2" (
    active = true
    append references = </grid>
)
{
    double3 xformOp:translate = (0, 0, 12)
    uniform token[] xformOpOrder = ["xformOp:translate"]

    over "mtl"
    {
        over "projected"
        {
            over "position"
            {
                string inputs:space = "map_proj:raster"
            }
        }
    }
}

def "grid_3" (
    active = true
    append references = </grid>
)
{
    double3 xformOp:translate = (12, 0, 12)
    uniform token[] xformOpOrder = ["xformOp:translate"]

    over "mtl"
    {
        over "projected"
        {
            over "position"
            {
                string inputs:space = "map_proj:screen"
            }
        }
    }
}

def Scope "Cameras"
{
    def Camera "renderCamera"
    {
        float2 clippingRange = (0.1, 10000)
        float focalLength = 24
        float horizontalAperture = 24
        token projection = "perspective"
        float verticalAperture = 18
        float xformOp:rotateX = -90
        double3 xformOp:translate = (6, 36, 6)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }
}
