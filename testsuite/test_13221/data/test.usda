#usda 1.0
(
    defaultPrim = "grid"
    doc = """Exercises Hydra CoordSys support: a texture is projected onto a
             ground plane from the coordinate system 'map_proj', which is bound
             to a tilted projector camera. The MaterialX position node reads its
             coordinates in the 'map_proj' space; arnold-usd rewrites that to the
             bound camera's OSL space so the projection follows the camera.

             See #32 / ARNOLD-13221."""
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "grid" (
    prepend apiSchemas = ["CoordSysAPI:map_proj"]
    kind = "component"
)
{
    rel coordSys:map_proj:binding = </grid/proj_cam>

    def Mesh "mesh" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        float3[] extent = [(-5, 0, -5), (5, 0, 5)]
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        rel material:binding = </grid/mtl/projected>
        point3f[] points = [(-5, 0, 5), (5, 0, 5), (5, 0, -5), (-5, 0, -5)]
        uniform token subdivisionScheme = "none"
    }

    def Camera "proj_cam"
    {
        float4[] clippingPlanes.timeSamples = {
            1: [],
        }
        float2 clippingRange = (0.1, 10000)
        float2 clippingRange.timeSamples = {
            1: (0.1, 10000),
        }
        float focalLength = 24
        float focalLength.timeSamples = {
            1: 24,
        }
        float focusDistance.timeSamples = {
            1: 0.910822,
        }
        float fStop.timeSamples = {
            1: 0,
        }
        float horizontalAperture = 36
        float horizontalAperture.timeSamples = {
            1: 36,
        }
        float horizontalApertureOffset.timeSamples = {
            1: 0,
        }
        token projection = "perspective"
        token projection.timeSamples = {
            1: "perspective",
        }
        float verticalAperture = 27
        float verticalAperture.timeSamples = {
            1: 27,
        }
        float verticalApertureOffset.timeSamples = {
            1: 0,
        }
        float xformOp:rotateX = -56
        matrix4d xformOp:transform.timeSamples = {
            1: ( (0.45165629697855614, -4.440892098500626e-16, -0.8921920137501895, 0), (-0.8056142649835146, 0.42972327873219796, -0.40782785556006496, 0), (0.38339567740741387, 0.9029606324284851, 0.19408722479766805, 0), (5.578332355740621, 11.791942779267115, 2.641486272343134, 1) ),
        }
        double3 xformOp:translate = (0, 12, 8)
        uniform token[] xformOpOrder = ["xformOp:transform"]
    }

    def Scope "mtl"
    {
        def Material "projected"
        {
            token outputs:mtlx:surface.connect = </grid/mtl/projected/surface.outputs:out>

            def Shader "surface"
            {
                uniform token info:id = "ND_surface_unlit"
                float inputs:emission = 1
                color3f inputs:emission_color.connect = </grid/mtl/projected/rgb.outputs:out>
                token outputs:out
            }

            def Shader "rgb"
            {
                uniform token info:id = "ND_combine3_color3"
                float inputs:in1.connect = </grid/mtl/projected/range_u.outputs:out>
                float inputs:in2.connect = </grid/mtl/projected/range_v.outputs:out>
                float inputs:in3 = 0
                color3f outputs:out
            }

            def Shader "range_u"
            {
                uniform token info:id = "ND_range_float"
                float inputs:in.connect = </grid/mtl/projected/separate.outputs:outx>
                float inputs:inhigh = 5
                float inputs:inlow = -5
                float inputs:outhigh = 1
                float inputs:outlow = 0
                float outputs:out
            }

            def Shader "range_v"
            {
                uniform token info:id = "ND_range_float"
                float inputs:in.connect = </grid/mtl/projected/separate.outputs:outy>
                float inputs:inhigh = 5
                float inputs:inlow = -5
                float inputs:outhigh = 1
                float inputs:outlow = 0
                float outputs:out
            }

            def Shader "separate"
            {
                uniform token info:id = "ND_separate3_vector3"
                vector3f inputs:in.connect = </grid/mtl/projected/position.outputs:out>
                float outputs:outx
                float outputs:outy
                float outputs:outz
            }

            def Shader "position"
            {
                uniform token info:id = "ND_position_vector3"
                string inputs:space = "map_proj"
                vector3f outputs:out
            }
        }
    }
}

def Scope "Cameras"
{
    def Camera "renderCamera"
    {
        float2 clippingRange = (0.1, 10000)
        float focalLength = 24
        float horizontalAperture = 24
        token projection = "perspective"
        float verticalAperture = 18
        float xformOp:rotateX = -90
        double3 xformOp:translate = (0, 22, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }
}

